- hourly_labels  = @hourly_series.map { |h| h[:hour].strftime("%-m/%-d %H:%M") }.to_json
- hourly_views   = @hourly_series.map { |h| h[:total_views] }.to_json
- hourly_sessions = @hourly_series.map { |h| h[:unique_sessions] }.to_json

- daily_labels   = @daily_series.map { |d| d[:date].strftime("%-m/%-d") }.to_json
- daily_views    = @daily_series.map { |d| d[:total_views] }.to_json
- daily_users    = @daily_series.map { |d| d[:unique_users] }.to_json

%h1.text-2xl.font-bold.text-gray-900.mb-2 Analytics Dashboard

%p.text-sm.text-gray-500.mb-6
  First-party page-view data. Raw events are retained for 90 days; charts read pre-aggregated rollup tables.

= form_with url: analytics_dashboard_path, method: :get, local: true, class: "flex items-center gap-3 mb-8" do |f|
  %label.text-sm.font-medium.text-gray-700{ for: "range" } Time range:
  = f.select :range,
      options_for_select([["Last 24 hours", "24h"], ["Last 7 days", "7d"], ["Last 30 days", "30d"]], @range),
      {},
      { id: "range", class: "rounded border-gray-300 text-sm shadow-sm focus:ring-blue-500 focus:border-blue-500", onchange: "this.form.submit()" }

-# ── Summary stat cards ───────────────────────────────────────────────────────
.grid.grid-cols-2.gap-4.sm:grid-cols-4.mb-8
  = render "analytics_dashboard/stat_card", label: "Total Views",       value: number_with_delimiter(@summary[:total_views])
  = render "analytics_dashboard/stat_card", label: "Unique Sessions",   value: number_with_delimiter(@summary[:unique_sessions])
  = render "analytics_dashboard/stat_card", label: "Unique Users",      value: number_with_delimiter(@summary[:unique_users])
  = render "analytics_dashboard/stat_card", label: "Authenticated",     value: number_with_delimiter(@summary[:authenticated_views])

-# ── Hourly traffic chart ─────────────────────────────────────────────────────
.bg-white.rounded-lg.shadow.p-6.mb-6
  %h2.text-lg.font-semibold.text-gray-800.mb-4 Hourly Traffic
  - if @hourly_series.empty?
    %p.text-gray-400.text-sm No data for this period yet.
  - else
    .relative{ style: "height: 260px" }
      %canvas{ data: {
        controller: "analytics-chart",
        "analytics-chart-type-value": "bar",
        "analytics-chart-labels-value": hourly_labels,
        "analytics-chart-datasets-value": [
          { label: "Page Views",      data: hourly_views,    backgroundColor: "rgba(30,64,175,0.7)" },
          { label: "Unique Sessions", data: hourly_sessions, backgroundColor: "rgba(251,191,36,0.7)", type: "line", fill: false, tension: 0.3 }
        ].to_json
      } }

-# ── Daily trend chart ────────────────────────────────────────────────────────
.bg-white.rounded-lg.shadow.p-6.mb-6
  %h2.text-lg.font-semibold.text-gray-800.mb-4 Daily Trends
  - if @daily_series.empty?
    %p.text-gray-400.text-sm No data for this period yet.
  - else
    .relative{ style: "height: 260px" }
      %canvas{ data: {
        controller: "analytics-chart",
        "analytics-chart-type-value": "line",
        "analytics-chart-labels-value": daily_labels,
        "analytics-chart-datasets-value": [
          { label: "Page Views",    data: daily_views, borderColor: "rgb(30,64,175)",   backgroundColor: "rgba(30,64,175,0.1)", fill: true,  tension: 0.3 },
          { label: "Unique Users",  data: daily_users, borderColor: "rgb(251,191,36)",  backgroundColor: "rgba(251,191,36,0.1)", fill: false, tension: 0.3 }
        ].to_json
      } }

-# ── Top pages table ──────────────────────────────────────────────────────────
.bg-white.rounded-lg.shadow.overflow-hidden
  %h2.text-lg.font-semibold.text-gray-800.px-6.pt-6.pb-3 Top Pages
  - if @top_pages.empty?
    %p.text-gray-400.text-sm.px-6.pb-6 No data for this period yet.
  - else
    %table.min-w-full.divide-y.divide-gray-200
      %thead.bg-gray-50
        %tr
          %th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Page
          %th.px-6.py-3.text-right.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Views
          %th.px-6.py-3.text-right.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Sessions
          %th.px-6.py-3.text-right.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Users
      %tbody.bg-white.divide-y.divide-gray-200
        - @top_pages.each do |page|
          %tr
            %td.px-6.py-3.text-sm.font-mono.text-gray-700= page[:page]
            %td.px-6.py-3.text-sm.text-right.text-gray-900= number_with_delimiter(page[:total_views])
            %td.px-6.py-3.text-sm.text-right.text-gray-600= number_with_delimiter(page[:unique_sessions])
            %td.px-6.py-3.text-sm.text-right.text-gray-600= number_with_delimiter(page[:unique_users])
