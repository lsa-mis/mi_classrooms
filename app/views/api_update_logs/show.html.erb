<div class="container px-1 mb-20">
  <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-2 mb-6">
    <div>
      <h1>API Update Run</h1>
      <p class="text-sm text-gray-600"><%= @api_update_log.created_at.strftime("%b %-d, %Y %-l:%M %p") %></p>
    </div>
    <%= link_to "Back to summary", api_update_logs_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>

  <%= render "run_summary", api_update_log: @api_update_log %>

  <section class="mt-8 rounded-lg bg-white border border-gray-200 p-4 shadow-sm">
    <h2 class="text-lg font-semibold text-gray-900">Raw Saved Report</h2>
    <pre class="mt-3 whitespace-pre-wrap text-sm text-gray-700"><%= @api_update_log.result %></pre>
  </section>
</div>
