<% counters = phase.fetch("counters", {}).select { |_name, value| value.to_i.positive? } %>
<% warnings = phase.fetch("warnings", []) %>
<% errors = phase.fetch("errors", []) %>

<section class="bg-white rounded-lg shadow-md border border-gray-200 p-4">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
    <div>
      <h3 class="text-lg font-semibold text-gray-900"><%= phase["phase"] %></h3>
      <p class="text-sm text-gray-600">
        <%= phase["duration_seconds"] || "0.0" %> seconds
      </p>
    </div>
    <span class="inline-flex w-fit rounded-full px-3 py-1 text-sm font-medium <%= phase["status"] == "success" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800" %>">
      <%= phase["status"].to_s.titleize %>
    </span>
  </div>

  <% if counters.present? %>
    <dl class="mt-4 grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      <% counters.each do |name, value| %>
        <div class="rounded-md bg-gray-50 p-3">
          <dt class="text-xs uppercase tracking-wide text-gray-500"><%= name.to_s.humanize %></dt>
          <dd class="text-xl font-semibold text-gray-900"><%= value %></dd>
        </div>
      <% end %>
    </dl>
  <% end %>

  <% if warnings.present? || errors.present? %>
    <div class="mt-4 space-y-2">
      <% warnings.each do |warning| %>
        <p class="rounded-md bg-yellow-50 p-3 text-sm text-yellow-900"><%= warning %></p>
      <% end %>
      <% errors.each do |error| %>
        <p class="rounded-md bg-red-50 p-3 text-sm text-red-900"><%= error %></p>
      <% end %>
    </div>
  <% end %>
</section>
