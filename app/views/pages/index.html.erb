<div class="container px-1 mb-20">
  <div class="relative overflow-hidden -mx-10 -mt-6">
    <!-- Decorative background image and gradient -->
    <div aria-hidden="true" class="absolute inset-x-0 top-0 h-44 sm:h-52 lg:h-56">
      <div class="absolute inset-0 max-w-7xl mx-auto overflow-hidden xl:px-8">
        <div class="w-full h-full">
          <%= link_to image_tag('cube.jpg', class: "block w-full h-5/6 object-cover object-top", alt: "#{(t :sitename)} Logo, link to home page.", id: "hero-image"), root_path, class: "block w-full h-full", tabindex: '-1' %>
        </div>
      </div>
      <div class="absolute inset-0 bg-white/25"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-white via-white/70 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-b from-transparent via-white/70 to-white"></div>
    </div>
    <section aria-labelledby="sale-heading" class="relative max-w-7xl mx-auto px-20 pt-32 px-4 flex flex-col items-center text-center sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto lg:max-w-none">
        <h1 class="leading-none font-extrabold tracking-tight text-gray-900" id="sale-heading" style="font-size: 4rem;">
          Makes finding the right room easy!
        </h1>
        <p class="mt-4 max-w-xl md:max-w-3xl mx-auto text-xl text-gray-700">
          MClassrooms provides an intuitive, accessible interface to find the room you are looking for. Whether you are an instructor searching for a classroom with the technologies to meet your pedagogy, a student trying to find their way to class, or a staff member looking to schedule a room, MClassrooms has your back.
        </p>
       
          <% if current_user %>
              <%= button_to rooms_path, class: "mt-10", method: :get do %>
                <div class="focus:ring focus:ring-offset-2 focus:ring-blue-400 inline-block w-full bg-gray-900 border border-transparent rounded-md py-3 px-8 font-medium text-white hover:bg-gray-800 sm:w-auto mb-10 sm:mb-0">Find A Room!</div>
              <% end %>
          <% else %>
            <%= button_to user_saml_omniauth_authorize_path, class: "mt-10", data: {turbo: "false"} do %>
              <div class="focus:ring focus:ring-offset-2 focus:ring-blue-400 inline-block w-full bg-gray-900 border border-transparent rounded-md py-3 px-8 font-medium text-white hover:bg-gray-800 sm:w-auto mb-10 sm:mb-0">Log In To Find A Room!</div>
            <% end %>
          <% end %>

      </div>
    </section>
  </div>
  <div class="relative static-page-text">
    <% unless @index_page_announcement.nil? %>
      <%= @index_page_announcement.content %>
    <% end %>
  </div>
  <div>
    <% if current_user && policy(Announcement).edit? && @index_page_announcement.present?%>
      <%= link_to edit_announcement_path(@index_page_announcement) do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          <title>Edit announcement</title>
        </svg>
      <% end %>
    <% end %>
  </div>
</div>
