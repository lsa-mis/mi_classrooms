<div class="container px-1 mb-20">
  <h1>Room Filters Glossary</h1>
  <p class="text-sm text-gray-700 mb-2">
  Filter names and definitions match the categories used on the <%= link_to "classrooms page", rooms_path, class: "text-blue-800 hover:underline" %>.
  </p>

  <nav aria-label="Alphabetical index" class="flex flex-wrap py-2">
    <% ("A".."Z").each do |char| %>
      <% if @category_letters.include?(char) %>
        <% first_category = @glossary_categories.keys.find { |category| category[0] == char } %>
        <%= link_to char,
          room_filters_glossary_path(anchor: glossary_category_anchor(first_category)),
          class: "p-2 text-sm text-black hover:underline" %>
      <% else %>
        <span class="p-2 text-sm text-gray-400"><%= char %></span>
      <% end %>
    <% end %>
  </nav>

  <% @glossary_categories.each do |category, list| %>
    <section id="<%= glossary_category_anchor(category) %>" class="mb-6 scroll-mt-4">
      <h2 class="text-xl font-semibold border-b border-gray-200 pb-1 mb-3"><%= category %></h2>
      <ul class="ml-4 text-base space-y-3">
        <% list.each do |filter, label| %>
          <li id="<%= glossary_filter_anchor(filter) %>" class="scroll-mt-4">
            <span class="font-semibold"><%= label %>:</span>
            <span class="font-normal"><%= room_characteristic_definitions[filter] %></span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>
